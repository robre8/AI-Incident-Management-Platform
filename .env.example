# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# SQL Server SA password (local Docker only)
SA_PASSWORD=YourStrong!Passw0rd

# MongoDB credentials (local Docker only)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=YourMongoPassw0rd

# AWS credentials (optional — only needed for S3 file upload feature)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS S3 bucket for file attachments
AWS_S3_APP_BUCKET=your-s3-bucket-name
AWS_S3_APP_REGION=us-east-1

# API key for endpoint protection (leave empty to disable)
API_KEY=
